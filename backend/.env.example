# Copy this file to ".env" and fill in real values before deploying.
# (The real .env is git-ignored and must NOT be committed.)

# --- Security (CHANGE THESE) ---
# A long random string. Generate one with:  openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Staff login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# --- CORS ---
# In production set this to your site, e.g. https://www.bargemini.it
# (comma-separated if more than one). Leave * only for local development.
ALLOW_ORIGINS=*

# --- Database ---
# Point this at a persistent disk/volume in production so data survives restarts.
# Example on a mounted volume:  DATABASE_PATH=/data/bargemini.db
# DATABASE_PATH=

# --- Email (optional) ---
# Confirmation/cancellation emails to customers. If left as placeholders the
# app logs a mock email instead of trying (and failing) to send.
# For Gmail use an App Password (not your normal password).
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=noreply@bargemini.it
